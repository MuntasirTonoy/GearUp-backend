model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  phone        String
  profilePhoto String?
  role         Role     @default(CUSTOMER)
  isDeleted    Boolean  @default(false)
  isSuspended  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider Provider?
  rentals  Rental[]
  reviews  Review[]

  @@index([email])
  @@index([role])
  @@map("users")
}
